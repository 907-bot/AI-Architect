# =============================================
# AI ARCHITECT — ENVIRONMENT VARIABLES
# =============================================

# --- OpenRouter (Free AI Models) ---
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# --- Cloudflare R2 ---
CLOUDFLARE_R2_ACCESS_KEY=your-r2-access-key
CLOUDFLARE_R2_SECRET_KEY=your-r2-secret-key
CLOUDFLARE_R2_BUCKET=ai-architect-scenes
CLOUDFLARE_R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com

# --- Upstash Redis ---
UPSTASH_REDIS_URL=redis://default:your-token@your-endpoint.upstash.io:6379
UPSTASH_REDIS_TOKEN=your-token

# --- HuggingFace ---
HUGGINGFACE_API_TOKEN=hf_your_token_here

# --- Replicate (GPU inference fallback) ---
REPLICATE_API_TOKEN=r8_your_token_here

# --- GitHub MCP ---
GITHUB_TOKEN=ghp_your_token_here

# --- JWT Secret ---
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# --- App Config ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NODE_ENV=development
